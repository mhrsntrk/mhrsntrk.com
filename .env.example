# Copy to .env.local and fill in. Never commit real values.

# --- Strapi (content) ---
STRAPI_API_URL=https://your-strapi-host
STRAPI_API_TOKEN=
STRAPI_API_TOKEN_FULL=

# --- Listmonk (newsletter) ---
# Base URL of your Listmonk instance, no trailing slash.
LISTMONK_URL=https://listmonk.your-host
# API user + token from Listmonk admin (Settings -> API users). Server-side only.
LISTMONK_API_USER=
LISTMONK_API_TOKEN=
# Numeric ID of the list new subscribers are added to (must be double opt-in).
LISTMONK_LIST_ID=

# --- Umami (analytics) ---
# Currently hardcoded in pages/_app.js; these are for a future env-driven refactor.
NEXT_PUBLIC_UMAMI_URL=https://umami.dev.mhrsntrk.com
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# --- Swiss Knife tools ---
NEXT_PUBLIC_ETHERSCAN_API_KEY=
NEXT_PUBLIC_INFURA_API_KEY=
NEXT_PUBLIC_QROXY_API=
